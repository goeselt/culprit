{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Update Project",
      "type": "shell",
      "command": "bash",
      "args": ["-lc", "npm install && npm run update && npm run verify"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}
